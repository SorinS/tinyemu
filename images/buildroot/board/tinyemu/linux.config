# TinyEMU kernel config fragment
# Applied on top of arch/riscv/configs/defconfig
# Reference: docs/image-build-plan-1769311563.md

# Size optimization
CONFIG_CC_OPTIMIZE_FOR_SIZE=y
CONFIG_EMBEDDED=y
CONFIG_EXPERT=y

# Console - Use VirtIO console for input/output
# NOTE: Disable HVC_RISCV_SBI so VirtIO console becomes hvc0
# SBI console is output-only (no input) so it can't be used for interactive shells
CONFIG_RISCV_SBI_V01=y
CONFIG_HVC_DRIVER=y
CONFIG_HVC_RISCV_SBI=n

# Early console via SBI - enables kernel output during early boot
# Used with kernel command line: earlycon=sbi
CONFIG_SERIAL_EARLYCON_RISCV_SBI=y

# VirtIO (required for TinyEMU - uses MMIO, not PCI)
CONFIG_VIRTIO_MENU=y
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=y

# Networking - minimal for userspace TCP/IP
CONFIG_NET=y
CONFIG_PACKET=y
CONFIG_UNIX=y
CONFIG_INET=y
# Use userspace DHCP (udhcpc), not kernel
CONFIG_IP_PNP=n
CONFIG_IP_PNP_DHCP=n

# Filesystems
CONFIG_EXT4_FS=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_TMPFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# ========================================
# DISABLE UNNECESSARY SUBSYSTEMS FOR SIZE
# ========================================

# No PCI - TinyEMU uses MMIO for VirtIO
CONFIG_PCI=n

# No physical serial ports - we use HVC via SBI
CONFIG_SERIAL_8250=n
CONFIG_SERIAL_SIFIVE=n
CONFIG_SERIAL_SH_SCI=n

# No physical ethernet - we use VirtIO
CONFIG_NET_VENDOR_3COM=n
CONFIG_NET_VENDOR_ADAPTEC=n
CONFIG_NET_VENDOR_AGERE=n
CONFIG_NET_VENDOR_ALACRITECH=n
CONFIG_NET_VENDOR_ALLWINNER=n
CONFIG_NET_VENDOR_ALTEON=n
CONFIG_NET_VENDOR_AMAZON=n
CONFIG_NET_VENDOR_AMD=n
CONFIG_NET_VENDOR_AQUANTIA=n
CONFIG_NET_VENDOR_ARC=n
CONFIG_NET_VENDOR_ASIX=n
CONFIG_NET_VENDOR_ATHEROS=n
CONFIG_NET_VENDOR_BROADCOM=n
CONFIG_NET_VENDOR_CADENCE=n
CONFIG_NET_VENDOR_CAVIUM=n
CONFIG_NET_VENDOR_CHELSIO=n
CONFIG_NET_VENDOR_CISCO=n
CONFIG_NET_VENDOR_CORTINA=n
CONFIG_NET_VENDOR_DAVICOM=n
CONFIG_NET_VENDOR_DEC=n
CONFIG_NET_VENDOR_DLINK=n
CONFIG_NET_VENDOR_EMULEX=n
CONFIG_NET_VENDOR_ENGLEDER=n
CONFIG_NET_VENDOR_EZCHIP=n
CONFIG_NET_VENDOR_FUNGIBLE=n
CONFIG_NET_VENDOR_GOOGLE=n
CONFIG_NET_VENDOR_HUAWEI=n
CONFIG_NET_VENDOR_I825XX=n
CONFIG_NET_VENDOR_INTEL=n
CONFIG_NET_VENDOR_ADI=n
CONFIG_NET_VENDOR_LITEX=n
CONFIG_NET_VENDOR_MARVELL=n
CONFIG_NET_VENDOR_MEDIATEK=n
CONFIG_NET_VENDOR_MELLANOX=n
CONFIG_NET_VENDOR_MICREL=n
CONFIG_NET_VENDOR_MICROCHIP=n
CONFIG_NET_VENDOR_MICROSEMI=n
CONFIG_NET_VENDOR_MICROSOFT=n
CONFIG_NET_VENDOR_MYRI=n
CONFIG_NET_VENDOR_NATSEMI=n
CONFIG_NET_VENDOR_NETERION=n
CONFIG_NET_VENDOR_NETRONOME=n
CONFIG_NET_VENDOR_NI=n
CONFIG_NET_VENDOR_NVIDIA=n
CONFIG_NET_VENDOR_OKI=n
CONFIG_NET_VENDOR_PACKET_ENGINES=n
CONFIG_NET_VENDOR_PENSANDO=n
CONFIG_NET_VENDOR_QLOGIC=n
CONFIG_NET_VENDOR_BROCADE=n
CONFIG_NET_VENDOR_QUALCOMM=n
CONFIG_NET_VENDOR_RDC=n
CONFIG_NET_VENDOR_REALTEK=n
CONFIG_NET_VENDOR_RENESAS=n
CONFIG_NET_VENDOR_ROCKER=n
CONFIG_NET_VENDOR_SAMSUNG=n
CONFIG_NET_VENDOR_SEEQ=n
CONFIG_NET_VENDOR_SILAN=n
CONFIG_NET_VENDOR_SIS=n
CONFIG_NET_VENDOR_SMSC=n
CONFIG_NET_VENDOR_SOCIONEXT=n
CONFIG_NET_VENDOR_SOLARFLARE=n
CONFIG_NET_VENDOR_STMICRO=n
CONFIG_NET_VENDOR_SUN=n
CONFIG_NET_VENDOR_SYNOPSYS=n
CONFIG_NET_VENDOR_TEHUTI=n
CONFIG_NET_VENDOR_TI=n
CONFIG_NET_VENDOR_TOSHIBA=n
CONFIG_NET_VENDOR_TUNDRA=n
CONFIG_NET_VENDOR_VIA=n
CONFIG_NET_VENDOR_WIZNET=n
CONFIG_NET_VENDOR_WANGXUN=n
CONFIG_NET_VENDOR_XILINX=n

# No netfilter/iptables
CONFIG_NETFILTER=n

# No advanced networking features
CONFIG_BRIDGE=n
CONFIG_VLAN_8021Q=n
CONFIG_NET_SCHED=n
CONFIG_CAN=n
CONFIG_BT=n
CONFIG_WIRELESS=n
CONFIG_WLAN=n

# No sound
CONFIG_SOUND=n

# No USB
CONFIG_USB_SUPPORT=n

# No graphics
CONFIG_DRM=n
CONFIG_FB=n
CONFIG_VGA_CONSOLE=n
CONFIG_FRAMEBUFFER_CONSOLE=n
CONFIG_LOGO=n

# No input devices
CONFIG_INPUT_MOUSE=n
CONFIG_INPUT_KEYBOARD=n
CONFIG_INPUT_TOUCHSCREEN=n
CONFIG_INPUT_MISC=n
CONFIG_INPUT_JOYSTICK=n

# No HID
CONFIG_HID=n

# No I2C/SPI (no physical buses)
CONFIG_I2C=n
CONFIG_SPI=n

# No hardware monitoring
CONFIG_HWMON=n
CONFIG_THERMAL=n

# No power management
CONFIG_REGULATOR=n
CONFIG_POWER_SUPPLY=n

# No watchdog
CONFIG_WATCHDOG=n

# No RTC (use system time)
CONFIG_RTC_CLASS=n

# No MMC/SD
CONFIG_MMC=n

# No IOMMU
CONFIG_IOMMU_SUPPORT=n

# No storage except VirtIO
CONFIG_ATA=n
CONFIG_SCSI=n
CONFIG_MD=n
CONFIG_NVME_CORE=n

# No PCMCIA/CardBus
CONFIG_PCMCIA=n
CONFIG_PCCARD=n

# No filesystems we don't need
CONFIG_NFS_FS=n
CONFIG_CIFS=n
CONFIG_NETWORK_FILESYSTEMS=n
CONFIG_ISO9660_FS=n
CONFIG_FAT_FS=n
CONFIG_BTRFS_FS=n
CONFIG_F2FS_FS=n
CONFIG_EROFS_FS=n
CONFIG_SQUASHFS=n

# No security frameworks
CONFIG_SECURITY=n
CONFIG_SECURITYFS=n

# Minimal crypto (keep what networking needs)
CONFIG_CRYPTO_USER=n
CONFIG_CRYPTO_USER_API=n

# No debug
CONFIG_DEBUG_KERNEL=n
CONFIG_PRINTK_TIME=n
CONFIG_DEBUG_INFO=n
CONFIG_DEBUG_FS=n

# No ftrace/profiling
CONFIG_FTRACE=n
CONFIG_FUNCTION_TRACER=n
CONFIG_KPROBES=n

# No modules (everything built-in for simplicity)
CONFIG_MODULES=n

# No BPF (large subsystem)
CONFIG_BPF_SYSCALL=n

# No cgroups (container features)
CONFIG_CGROUPS=n

# No namespaces (container features)
CONFIG_NAMESPACES=n

# No audit
CONFIG_AUDIT=n

# No perf events
CONFIG_PERF_EVENTS=n

# Minimal block layer
CONFIG_BLK_DEV_BSG=n
CONFIG_BLK_DEV_BSGLIB=n

# No IPv6 (optional, saves space)
CONFIG_IPV6=n

# No misc kernel features we don't need
CONFIG_PROFILING=n
CONFIG_KEXEC=n
CONFIG_CRASH_DUMP=n
CONFIG_HUGETLBFS=n
CONFIG_HUGETLB_PAGE=n
CONFIG_TRANSPARENT_HUGEPAGE=n
CONFIG_SWAP=n
CONFIG_SLAB_FREELIST_RANDOM=n
CONFIG_COMPAT_BRK=n

# Smaller printk buffer
CONFIG_LOG_BUF_SHIFT=14

# No kernel symbols for size
CONFIG_KALLSYMS=n

# No ACPI (we use devicetree)
CONFIG_ACPI=n

# Only SOC_VIRT needed - disable real hardware SoCs
CONFIG_SOC_MICROCHIP_POLARFIRE=n
CONFIG_SOC_SIFIVE=n
CONFIG_SOC_STARFIVE=n

# No real hardware clock/pinctrl/gpio drivers
CONFIG_CLK_SIFIVE=n
CONFIG_CLK_STARFIVE_JH71X0=n
CONFIG_CLK_STARFIVE_JH7100=n
CONFIG_CLK_STARFIVE_JH7100_AUDIO=n
CONFIG_CLK_STARFIVE_JH7110_PLL=n
CONFIG_CLK_RENESAS=n
CONFIG_PINCTRL_STARFIVE_JH7100=n
CONFIG_PINCTRL_STARFIVE_JH7110=n
CONFIG_PINCTRL_SUNXI=n
CONFIG_PINCTRL_RENESAS=n
CONFIG_GPIO_SIFIVE=n
CONFIG_DMA_SUN6I=n

# No RPMSG (remote processor messaging)
CONFIG_RPMSG=n

# No EFI - TinyEMU boots raw kernel directly, not via EFI
# NONPORTABLE disables PORTABLE which would otherwise force-select EFI
CONFIG_NONPORTABLE=y
# CONFIG_EFI is not set
# CONFIG_EFI_STUB is not set

# No errata workarounds for specific CPUs
CONFIG_ERRATA_SIFIVE=n
CONFIG_ERRATA_STARFIVE_JH7100=n
CONFIG_ERRATA_THEAD=n

# Disable more unneeded features
CONFIG_CPU_FREQ=n
CONFIG_CPU_IDLE=n
CONFIG_PM=n
CONFIG_SUSPEND=n
CONFIG_HIBERNATION=n

# No RAM disk (keep loop devices)
CONFIG_BLK_DEV_RAM=n

# Minimal TTY
CONFIG_VT=n
CONFIG_LEGACY_PTYS=n

# No misc char devices
CONFIG_DEVMEM=n
CONFIG_DEVKMEM=n
