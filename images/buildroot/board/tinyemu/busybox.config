# TinyEMU minimal busybox configuration
# Reference: docs/image-build-plan-1769311563.md
#
# This is a minimal config enabling only applets needed for:
# - Boot/init
# - Networking (DHCP client)
# - Basic system administration

CONFIG_BUSYBOX=y
CONFIG_FEATURE_BUFFERS_USE_MALLOC=y
CONFIG_SHOW_USAGE=y
CONFIG_FEATURE_VERBOSE_USAGE=y
CONFIG_LONG_OPTS=y
CONFIG_FEATURE_DEVPTS=y
CONFIG_PID_FILE_PATH="/var/run"
CONFIG_BUSYBOX_EXEC_PATH="/proc/self/exe"

# Build options
CONFIG_STATIC=n
CONFIG_BUILD_LIBBUSYBOX=n
CONFIG_FEATURE_LIBBUSYBOX_STATIC=n
CONFIG_FEATURE_INSTALLER=n
CONFIG_INSTALL_APPLET_SYMLINKS=y
CONFIG_INSTALL_APPLET_HARDLINKS=n
CONFIG_PREFIX="./_install"

# General configuration
CONFIG_DESKTOP=n
CONFIG_EXTRA_COMPAT=n
CONFIG_INCLUDE_SUSv2=n
CONFIG_USE_PORTABLE_CODE=n
CONFIG_PLATFORM_LINUX=y
CONFIG_FEATURE_PREFER_APPLETS=y
CONFIG_BUSYBOX_EXEC_PATH="/proc/self/exe"

# Init
CONFIG_INIT=y
CONFIG_LINUXRC=y
CONFIG_FEATURE_USE_INITTAB=y
CONFIG_FEATURE_INIT_SCTTY=y
CONFIG_FEATURE_INIT_SYSLOG=y
CONFIG_FEATURE_INIT_QUIET=y
CONFIG_FEATURE_INIT_COREDUMPS=n
CONFIG_INIT_TERMINAL_TYPE="linux"
CONFIG_HALT=y
CONFIG_POWEROFF=y
CONFIG_REBOOT=y

# Shell
CONFIG_ASH=y
CONFIG_ASH_OPTIMIZE_FOR_SIZE=y
CONFIG_ASH_INTERNAL_GLOB=y
CONFIG_ASH_BASH_COMPAT=y
CONFIG_ASH_JOB_CONTROL=y
CONFIG_ASH_ALIAS=y
CONFIG_ASH_GETOPTS=y
CONFIG_ASH_BUILTIN_ECHO=y
CONFIG_ASH_BUILTIN_PRINTF=y
CONFIG_ASH_BUILTIN_TEST=y
CONFIG_ASH_CMDCMD=y
CONFIG_ASH_EXPAND_PRMT=y
CONFIG_ASH_IDLE_TIMEOUT=n
CONFIG_ASH_MAIL=n
CONFIG_ASH_RANDOM_SUPPORT=y
CONFIG_FEATURE_SH_MATH=y
CONFIG_FEATURE_SH_MATH_64=y
CONFIG_SH_MATH_SUPPORT_64=y

# Login/passwd (minimal)
CONFIG_LOGIN=y
CONFIG_FEATURE_SHADOWPASSWDS=y
CONFIG_USE_BB_PWD_GRP=y
CONFIG_GETTY=y
CONFIG_PASSWD=n
CONFIG_ADDUSER=n
CONFIG_ADDGROUP=n
CONFIG_DELUSER=n
CONFIG_DELGROUP=n
CONFIG_SU=n

# File utilities
CONFIG_CAT=y
CONFIG_CHMOD=y
CONFIG_CHOWN=y
CONFIG_CP=y
CONFIG_DD=y
CONFIG_DF=y
CONFIG_ECHO=y
CONFIG_FEATURE_FANCY_ECHO=y
CONFIG_FALSE=y
CONFIG_HEAD=y
CONFIG_LN=y
CONFIG_LS=y
CONFIG_FEATURE_LS_FILETYPES=y
CONFIG_FEATURE_LS_FOLLOWLINKS=y
CONFIG_FEATURE_LS_SORTFILES=y
CONFIG_FEATURE_LS_TIMESTAMPS=y
CONFIG_FEATURE_LS_USERNAME=y
CONFIG_MKDIR=y
CONFIG_MKNOD=y
CONFIG_MV=y
CONFIG_PWD=y
CONFIG_RM=y
CONFIG_RMDIR=y
CONFIG_SLEEP=y
CONFIG_SYNC=y
CONFIG_TAIL=y
CONFIG_TEE=y
CONFIG_TOUCH=y
CONFIG_TRUE=y
CONFIG_UNAME=y

# Text utilities
CONFIG_AWK=y
CONFIG_CUT=y
CONFIG_GREP=y
CONFIG_FEATURE_GREP_CONTEXT=y
CONFIG_SED=y
CONFIG_SORT=y
CONFIG_TR=y
CONFIG_UNIQ=y
CONFIG_WC=y

# System utilities
CONFIG_CLEAR=y
CONFIG_DATE=y
CONFIG_DMESG=y
CONFIG_ENV=y
CONFIG_FREE=y
CONFIG_HOSTNAME=y
CONFIG_ID=y
CONFIG_KILL=y
CONFIG_KILLALL=y
CONFIG_MOUNT=y
CONFIG_FEATURE_MOUNT_NFS=n
CONFIG_PIVOT_ROOT=y
CONFIG_PS=y
CONFIG_FEATURE_PS_LONG=y
CONFIG_SYSCTL=y
CONFIG_UMOUNT=y
CONFIG_UPTIME=y
CONFIG_WHICH=y

# Process utilities
CONFIG_NOHUP=y
CONFIG_PIDOF=y
CONFIG_SETSID=y
CONFIG_XARGS=y

# Networking
CONFIG_IP=y
CONFIG_FEATURE_IP_ADDRESS=y
CONFIG_FEATURE_IP_LINK=y
CONFIG_FEATURE_IP_ROUTE=y
CONFIG_FEATURE_IP_RULE=n
CONFIG_FEATURE_IP_TUNNEL=n
CONFIG_FEATURE_IP_NEIGH=y
CONFIG_IFCONFIG=y
CONFIG_FEATURE_IFCONFIG_STATUS=y
CONFIG_FEATURE_IFCONFIG_HW=y
CONFIG_FEATURE_IFCONFIG_BROADCAST_PLUS=y
CONFIG_PING=y
CONFIG_FEATURE_FANCY_PING=y
CONFIG_ROUTE=y
CONFIG_NETSTAT=y
CONFIG_NSLOOKUP=y
CONFIG_NC=y
CONFIG_WGET=y
CONFIG_FEATURE_WGET_LONG_OPTIONS=y
CONFIG_FEATURE_WGET_STATUSBAR=y
CONFIG_FEATURE_WGET_TIMEOUT=y

# DHCP client (critical for slirp)
CONFIG_UDHCPC=y
CONFIG_FEATURE_UDHCPC_ARPING=y
CONFIG_FEATURE_UDHCPC_SANITIZEOPT=y
CONFIG_UDHCPC_DEFAULT_SCRIPT="/etc/udhcpc.script"

# Syslog (for debugging)
CONFIG_SYSLOGD=y
CONFIG_FEATURE_SYSLOGD_DUP=n
CONFIG_FEATURE_SYSLOGD_CFG=n
CONFIG_KLOGD=y

# Disable everything else
CONFIG_FEATURE_HTTPD_BASIC_AUTH=n
CONFIG_HTTPD=n
CONFIG_TELNETD=n
CONFIG_FTPD=n
CONFIG_TFTPD=n
CONFIG_SENDMAIL=n
CONFIG_DNSD=n
CONFIG_NTPD=n
CONFIG_INETD=n
CONFIG_FEATURE_TELNET_AUTOLOGIN=n
CONFIG_FEATURE_TELNET_WIDTH=n
CONFIG_FTP=n
CONFIG_TFTP=n

# Archive utilities (minimal)
CONFIG_TAR=y
CONFIG_FEATURE_TAR_CREATE=y
CONFIG_FEATURE_TAR_AUTODETECT=y
CONFIG_FEATURE_TAR_FROM=y
CONFIG_FEATURE_TAR_GNU_EXTENSIONS=y
CONFIG_FEATURE_TAR_LONG_OPTIONS=y
CONFIG_GZIP=y
CONFIG_FEATURE_GZIP_DECOMPRESS=y

# Misc settings
CONFIG_FEATURE_SEAMLESS_GZ=y
CONFIG_FEATURE_SEAMLESS_BZ2=n
CONFIG_FEATURE_SEAMLESS_LZMA=n
CONFIG_FEATURE_SEAMLESS_XZ=n
CONFIG_FEATURE_SEAMLESS_Z=n
CONFIG_FEATURE_EDITING=y
CONFIG_FEATURE_EDITING_MAX_LEN=1024
CONFIG_FEATURE_EDITING_HISTORY=32
CONFIG_FEATURE_TAB_COMPLETION=y
CONFIG_FEATURE_EDITING_FANCY_PROMPT=y
CONFIG_FEATURE_EDITING_ASK_TERMINAL=n
CONFIG_FEATURE_NON_POSIX_CP=y
